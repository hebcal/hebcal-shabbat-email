{
  "compilerOptions": {
    "module": "es2022",
    "rootDir": "./src",
    "outDir": "dist",
    "esModuleInterop": true,
    "target": "es2023",
    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "sourceMap": false,
    "moduleResolution": "bundler",
    "composite": false,
    "skipLibCheck": true,
    "paths": {
      "*": ["./types/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ]
}
