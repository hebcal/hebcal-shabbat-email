{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "module": "es2022",
    "rootDir": "./src",
    "outDir": "dist",
    "esModuleInterop": true,
    "target": "es2023",
    "sourceMap": false,
    "moduleResolution": "bundler",
    "composite": false,
    "declaration": false,
    "strict": true,
    "paths": {
      "*": ["./types/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ]
}
